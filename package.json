{
  "name": "ai-user-flow",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/backend"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "backend:dev": "npm --workspace @ai-user-flow/backend run start:dev",
    "backend:build": "npm --workspace @ai-user-flow/backend run build",
    "backend:test": "npm --workspace @ai-user-flow/backend run test",
    "backend:test:e2e": "npm --workspace @ai-user-flow/backend run test:e2e",
    "backend:typecheck": "npm --workspace @ai-user-flow/backend run typecheck"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "mermaid": "^11.14.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitest/coverage-v8": "latest",
    "jsdom": "^26.1.0",
    "vitest": "latest"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
